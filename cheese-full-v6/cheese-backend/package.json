{
  "name": "cheese-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node -e \"const {execFileSync}=require('child_process');execFileSync(process.execPath,['node_modules/prisma/build/index.js','generate'],{stdio:'inherit'})\"",
    "dev":     "tsx watch src/index.ts",
    "start":   "node --import tsx/esm src/index.ts",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client":      "^5.22.0",
    "prisma":              "^5.22.0",
    "fastify":             "^4.28.0",
    "@fastify/cors":       "^9.0.1",
    "@fastify/jwt":        "^8.0.1",
    "@fastify/helmet":     "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "socket.io":           "^4.7.5",
    "grammy":              "^1.29.0",
    "zod":                 "^3.23.8",
    "dotenv":              "^16.4.5",
    "pino-pretty":         "^11.0.0",
    "tsx":                 "^4.16.0"
  },
  "devDependencies": {
    "typescript":  "^5.5.3",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": "20.x"
  }
}
