generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  MODERATOR
  CASHIER
  COURIER
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  ON_THE_WAY
  DELIVERED
  CANCELLED
}

enum DeliveryType {
  DELIVERY
  PICKUP
}

enum PaymentType {
  CASH
  PAYME
  CLICK
}

enum DiscountType {
  FIXED
  PERCENT
}

model User {
  id          Int       @id @default(autoincrement())
  telegramId  BigInt    @unique
  firstName   String
  lastName    String?
  username    String?
  phone       String?
  photoUrl    String?
  role        Role      @default(USER)
  isBlocked   Boolean   @default(false)
  blockReason String?
  blockUntil  DateTime?
  bonusPoints Int       @default(0)
  lat         Float?
  lng         Float?
  lastSeenAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orders         Order[]        @relation("UserOrders")
  courierOrders  Order[]        @relation("CourierOrders")
  savedAddresses SavedAddress[]
  savedPromos    UserPromo[]
  auditLogs      AuditLog[]

  @@map("users")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  emoji     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  items MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  description String
  price       Int
  emoji       String
  imageUrl    String?
  prepTime    Int      @default(15)
  isAvailable Boolean  @default(true)
  isHot       Boolean  @default(false)
  isNew       Boolean  @default(false)
  rating      Float    @default(0)
  soldCount   Int      @default(0)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   Category    @relation(fields: [categoryId], references: [id])
  extras     Extra[]
  orderItems OrderItem[]

  @@map("menu_items")
}

model Extra {
  id         String @id @default(cuid())
  menuItemId String
  name       String
  price      Int

  menuItem        MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  orderItemExtras OrderItemExtra[]

  @@map("extras")
}

model Order {
  id           String       @id @default(cuid())
  orderNumber  String       @unique
  userId       Int
  courierId    Int?
  status       OrderStatus  @default(PENDING)
  deliveryType DeliveryType @default(DELIVERY)
  paymentType  PaymentType  @default(CASH)
  isPaid       Boolean      @default(false)

  address       String?
  addressDetail String?
  lat           Float?
  lng           Float?

  phone       String
  secondPhone String?

  subtotal    Int
  deliveryFee Int     @default(5000)
  discount    Int     @default(0)
  totalPrice  Int
  promoCode   String?
  note        String?

  acceptedAt   DateTime?
  preparedAt   DateTime?
  pickedAt     DateTime?
  deliveredAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User        @relation("UserOrders",    fields: [userId],    references: [id])
  courier User?       @relation("CourierOrders", fields: [courierId], references: [id])
  items   OrderItem[]

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  price      Int
  note       String?

  order    Order            @relation(fields: [orderId],    references: [id], onDelete: Cascade)
  menuItem MenuItem         @relation(fields: [menuItemId], references: [id])
  extras   OrderItemExtra[]

  @@map("order_items")
}

model OrderItemExtra {
  id          String @id @default(cuid())
  orderItemId String
  extraId     String
  price       Int

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  extra     Extra     @relation(fields: [extraId],     references: [id])

  @@map("order_item_extras")
}

model PromoCode {
  id           String       @id @default(cuid())
  code         String       @unique
  discountType DiscountType @default(FIXED)
  discount     Int
  minOrder     Int          @default(0)
  maxUses      Int?
  usedCount    Int          @default(0)
  expiresAt    DateTime?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())

  userPromos UserPromo[]

  @@map("promo_codes")
}

model UserPromo {
  id          String    @id @default(cuid())
  userId      Int
  promoCodeId String
  savedAt     DateTime  @default(now())
  usedAt      DateTime?

  user      User      @relation(fields: [userId],      references: [id])
  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])

  @@unique([userId, promoCodeId])
  @@map("user_promos")
}

model BonusReward {
  id             String  @id @default(cuid())
  name           String
  emoji          String
  pointsRequired Int
  menuItemId     String?
  isActive       Boolean @default(true)

  @@map("bonus_rewards")
}

model SavedAddress {
  id      String  @id @default(cuid())
  userId  Int
  label   String
  address String
  detail  String?
  lat     Float?
  lng     Float?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_addresses")
}

model CafeSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("cafe_settings")
}

model WorkHours {
  id    String  @id @default(cuid())
  day   Int
  open  String
  close String
  isOff Boolean @default(false)

  @@unique([day])
  @@map("work_hours")
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   Int
  action    String
  entity    String
  entityId  String?
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@map("audit_logs")
}
